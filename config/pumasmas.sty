% --- Hyperlinks and Metadata ---
\RequirePackage{hyperref}
\hypersetup{
    colorlinks=true,
    linkcolor=cp-accent,
    urlcolor=cp-accent,
    citecolor=cp-accent,
    filecolor=cp-accent,
}
